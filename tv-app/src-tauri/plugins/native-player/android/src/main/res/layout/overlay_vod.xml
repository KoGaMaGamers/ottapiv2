<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/vodOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="false">

    <!-- Top gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_gradient_top" />

    <!-- Top bar: back + title -->
    <LinearLayout
        android:id="@+id/vodTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="22dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/vodBackBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:background="@drawable/bg_nav_btn"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/vodTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/vodSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Subtitle cue text (above bottom controls) -->
    <TextView
        android:id="@+id/vodSubtitleCue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:maxWidth="1720dp"
        android:maxLines="3"
        android:textColor="#FFFFFF"
        android:textSize="19sp"
        android:shadowColor="#CC000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:background="@drawable/bg_vod_subtitle_cue"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone" />

    <!-- Bottom gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_gradient_bottom" />

    <!-- Bottom controls area -->
    <LinearLayout
        android:id="@+id/vodControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:background="@drawable/bg_vod_controls_panel">

        <!-- ═══ ZONE 1: Seek bar ═══ -->
        <FrameLayout
            android:id="@+id/vodSeekBarContainer"
            android:layout_width="860dp"
            android:layout_height="24dp"
            android:layout_marginBottom="4dp">

            <!-- Background track -->
            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_gravity="center_vertical"
                android:background="@color/epg_progress_bg" />

            <!-- Buffered track -->
            <View
                android:id="@+id/vodBufferedFill"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_gravity="center_vertical"
                android:background="#59FFFFFF" />

            <!-- Played track -->
            <View
                android:id="@+id/vodPlayedFill"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_gravity="center_vertical"
                android:background="@color/epg_progress_fill" />

            <!-- Seek thumb -->
            <View
                android:id="@+id/vodSeekThumb"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/bg_seek_thumb"
                android:visibility="gone" />

            <!-- Seek focus indicator (border around entire bar when focused) -->
            <View
                android:id="@+id/vodSeekFocusRing"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/vodCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/vodDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ═══ ZONE 2: Control buttons ═══ -->
        <LinearLayout
            android:id="@+id/vodControlRow"
            android:layout_width="860dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Left spacer to center the playback controls -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Previous episode (series only, hidden by default) -->
            <TextView
                android:id="@+id/vodPrevEpisode"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⏮"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_control_btn"
                android:layout_marginEnd="20dp"
                android:visibility="gone" />

            <!-- Play / Pause -->
            <TextView
                android:id="@+id/vodPlayPause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="▶"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:background="@drawable/bg_control_btn_playpause" />

            <!-- Next episode (series only, hidden by default) -->
            <TextView
                android:id="@+id/vodNextEpisode"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⏭"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_control_btn"
                android:layout_marginStart="20dp"
                android:visibility="gone" />

            <!-- Right spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Subtitle language button -->
            <TextView
                android:id="@+id/vodCcBtn"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="SUB"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_control_btn"
                android:layout_marginEnd="8dp"
                android:visibility="visible" />

            <!-- Audio track button -->
            <TextView
                android:id="@+id/vodAudioBtn"
                android:layout_width="52dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="AUDIO"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_control_btn"
                android:layout_marginEnd="8dp"
                android:visibility="visible" />

            <!-- Subtitle adjustment button -->
            <TextView
                android:id="@+id/vodAdjustBtn"
                android:layout_width="52dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="ADJ"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_control_btn"
                android:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

    <!-- Subtitle selection menu (hidden by default) -->
    <LinearLayout
        android:id="@+id/vodSubMenu"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:maxHeight="480dp"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_vod_submenu_panel"
        android:padding="18dp"
        android:elevation="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/vodSubMenuTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subtitles"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="↑↓ navigate · Enter select · ← → adjust"
            android:textColor="#8AFFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="10dp" />

        <!-- Audio track row -->
        <LinearLayout
            android:id="@+id/vodAudioRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Audio track"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/vodAudioMinus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/bg_nav_btn" />

            <TextView
                android:id="@+id/vodAudioValue"
                android:layout_width="118dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="Auto"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/vodAudioPlus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/bg_nav_btn" />
        </LinearLayout>

        <!-- Subtitle size row -->
        <LinearLayout
            android:id="@+id/vodSubSizeRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Subtitle size"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/vodSubSizeMinus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="A−"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:background="@drawable/bg_nav_btn" />

            <TextView
                android:id="@+id/vodSubSizeValue"
                android:layout_width="64dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="20sp"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/vodSubSizePlus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="A+"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:background="@drawable/bg_nav_btn" />
        </LinearLayout>

        <!-- Sync offset row -->
        <LinearLayout
            android:id="@+id/vodSubSyncRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sync offset"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/vodSubSyncMinus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/bg_nav_btn" />

            <TextView
                android:id="@+id/vodSubSyncValue"
                android:layout_width="64dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="0.0s"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/vodSubSyncPlus"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/bg_nav_btn" />
        </LinearLayout>

        <!-- Scrollable subtitle track list -->
        <ScrollView
            android:id="@+id/vodSubTrackScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/vodSubTrackList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

</FrameLayout>
